<Window x:Class="Library_Manager.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Library_Manager"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="750">
    <Grid>
        <Label Content="Admin Panel" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" Margin="0,20,0,0"/>

        <TabControl>
            <TabItem Header="Users">
                <!-- tabela korisnika -->
                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- INPUT SECTION -->
                    <Border Grid.Row="0" Padding="10" BorderThickness="1" BorderBrush="Gray" CornerRadius="5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBox Width="150"
                         Margin="5"
                         Text="{Binding NameInput}" />

                            <TextBox Width="150"
                         Margin="5"
                         Text="{Binding IdNumberInput}" />

                            <CheckBox Content="Admin"
                          Margin="10,0"
                          IsChecked="{Binding IsAdminInput}" />

                            <TextBox Width="150"
                         Margin="5"
                         Text="{Binding PasswordInput}" />

                            <Button Content="Add User"
                        Width="100"
                        Margin="5"
                        Command="{Binding AddUserCommand}" />

                        </StackPanel>
                    </Border>

                    <!-- USERS TABLE -->
                    <DataGrid Grid.Row="1"
                  Margin="0,10,0,10"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="ID Number" Binding="{Binding IdNumber}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Admin" Binding="{Binding IsAdmin}" Width="100"/>

                            <!-- ACTIONS -->
                            <DataGridTemplateColumn Header="Actions" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                            <Button Content="Edit"
                                        Command="{Binding DataContext.UpdateUserCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Margin="2"
                                        Padding="5,2"/>

                                            <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Margin="2"
                                        Padding="5,2"
                                        Background="Red"
                                        Foreground="White"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- EMPTY MESSAGE -->
                    <TextBlock Text="No users yet"
                   FontSize="16"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.Row="1">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Users.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- FOOTER -->
                    <Border Grid.Row="2" Padding="10" BorderThickness="1" BorderBrush="Gray" CornerRadius="5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                            <Button Content="Refresh"
                        Width="100"
                        Command="{Binding LoadUsersCommand}" />

                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="Books">
                <!-- tabela knjiga -->
                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- INPUT SECTION -->
                    <Border Grid.Row="0" Padding="10" BorderThickness="1" BorderBrush="Gray" CornerRadius="5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBox Width="150"
                         Margin="5"
                         Text="{Binding TitleInput}" />

                            <TextBox Width="150"
                         Margin="5"
                         Text="{Binding AuthorInput}" />

                            <TextBox Width="120"
                         Margin="5"
                         Text="{Binding GenreInput}" />

                            <TextBox Width="80"
                         Margin="5"
                         Text="{Binding QuantityInput}" />

                            <Button Content="Add Book"
                        Width="100"
                        Margin="5"
                        Command="{Binding AddBookCommand}" />

                        </StackPanel>
                    </Border>

                    <!-- BOOKS TABLE -->
                    <DataGrid Grid.Row="1"
                  Margin="0,10,0,10"
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="150"/>
                            <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="120"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>

                            <!-- ACTIONS -->
                            <DataGridTemplateColumn Header="Actions" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                            <Button Content="Edit"
                                        Command="{Binding DataContext.UpdateBookCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Margin="2"
                                        Padding="5,2"/>

                                            <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteBookCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Margin="2"
                                        Padding="5,2"
                                        Background="Red"
                                        Foreground="White"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- EMPTY MESSAGE -->
                    <TextBlock Text="No books yet"
                   FontSize="16"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.Row="1">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Books.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- FOOTER -->
                    <Border Grid.Row="2" Padding="10" BorderThickness="1" BorderBrush="Gray" CornerRadius="5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                            <Button Content="Refresh"
                        Width="100"
                        Command="{Binding LoadBooksCommand}" />

                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
