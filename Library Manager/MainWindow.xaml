<Window x:Class="Library_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Library_Manager"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600">
    <Grid>
        <Label Content="Welcome to the Library Manager!" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" Margin="0,111,0,0"/>
        <Label Content="Please log in as a user or as an admin." HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,161,0,0" FontSize="18"/>
        <TextBox x:Name="Username"
         HorizontalAlignment="Center"
         VerticalAlignment="Top"
         Margin="0,200,0,0"
         Width="200"
         Height="30"
         FontSize="16"/>
        <PasswordBox x:Name="Password" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,240,0,0" Width="200" Height="30" FontSize="16"/>
        <Button Content="Login" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,300,0,0" Width="200" Height="30" FontSize="16" Click="Button_Click"/>
    </Grid>
</Window>
