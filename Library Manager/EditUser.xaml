<Window x:Class="Library_Manager.EditUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Library_Manager"
        mc:Ignorable="d"
        Title="EditUser" Height="450" Width="500">
    <Grid>
        <Label Content="Edit User" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" Margin="0,20,0,0"/>
        <Label Content="Username:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,100,0,0" FontSize="16"/>
        <TextBox x:Name="Username" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,100,0,0" Width="200" Height="30" FontSize="16" Text="{Binding EditingUser.Name}"/>
        <Label Content="Password:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,150,0,0" FontSize="16"/>
        <TextBox x:Name="Password" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,150,0,0" Width="200" Height="30" FontSize="16" Text="{Binding EditingUser.Password}"/>
        <Button Content="Save" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,200,0,0" Width="100" Height="30" FontSize="16" Command="{Binding SaveChanges}"/>
        <Button Content="Cancel" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="260,200,0,0" Width="100" Height="30" FontSize="16" Command="{Binding CancelChanges}"/>
    </Grid>
</Window>
