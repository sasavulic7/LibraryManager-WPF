<Window x:Class="Library_Manager.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Panel" Height="500" Width="900">

    <Grid Margin="10">

        <TabControl>

            <!-- TAB 1 -->
            <TabItem Header="All Books">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- search -->
                    <TextBox Height="30"
                             Margin="0,0,0,10"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             />

                   
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Books}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectedItem="{Binding SelectedBook}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
                            <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>

                            <!-- Borrow button -->
                            <DataGridTemplateColumn Header="Action" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Borrow"
                                                Command="{Binding DataContext.BorrowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="5"
                                                Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

           
            <TabItem Header="My Books">
                <Grid Margin="10">

                    <DataGrid ItemsSource="{Binding BorrowedBooks}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
                            <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </TabItem>

        </TabControl>

    </Grid>
</Window>